#!/usr/bin/env python3
"""Root sidecar for tightly-scoped Hermes gateway systemd control.

Listens on /run/hermes-gateway-control.sock and accepts one JSON request per
connection:
  {"action":"status|restart", "profile":"default|profile-name"}

It never executes shell strings. It maps validated profile names onto the two
provisioner-owned unit shapes only:
  agent-gateway.service
  agent-gateway@<profile>.service
"""
from __future__ import annotations

import json
import os
import pwd
import re
import signal
import socket
import subprocess
import sys
from pathlib import Path
from typing import Any

SOCKET_PATH = Path("/run/hermes-gateway-control.sock")
ALLOWED_ACTIONS = {"status", "restart"}
PROFILE_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_.-]{0,63}$")


def read_agent_env() -> dict[str, str]:
    env: dict[str, str] = {}
    path = Path("/etc/agent-lxc.env")
    if not path.exists():
        return env
    for raw in path.read_text(errors="replace").splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, val = line.split("=", 1)
        env[key] = val.strip().strip('"').strip("'")
    return env


def unit_for(profile: str | None) -> str:
    if not profile or profile == "default":
        return "agent-gateway.service"
    if not PROFILE_RE.match(profile):
        raise ValueError(f"invalid Hermes profile name: {profile}")
    return f"agent-gateway@{profile}.service"


def handle(req: dict[str, Any]) -> dict[str, Any]:
    action = req.get("action")
    profile = req.get("profile") or "default"
    if action not in ALLOWED_ACTIONS:
        return {"returncode": 2, "stdout": "", "stderr": f"unsupported action: {action}\n"}
    try:
        unit = unit_for(str(profile))
    except ValueError as exc:
        return {"returncode": 2, "stdout": "", "stderr": f"{exc}\n"}

    if action == "status":
        cmd = ["systemctl", "status", unit, "--no-pager"]
    else:
        cmd = ["systemctl", "restart", unit]

    proc = subprocess.run(cmd, text=True, capture_output=True, timeout=60)
    return {"returncode": proc.returncode, "stdout": proc.stdout, "stderr": proc.stderr}


def send(conn: socket.socket, payload: dict[str, Any]) -> None:
    conn.sendall(json.dumps(payload).encode() + b"\n")


def serve() -> int:
    if os.geteuid() != 0:
        print("hermes-gateway-control-daemon must run as root", file=sys.stderr)
        return 1

    env = read_agent_env()
    if env.get("AGENT") != "hermes":
        print("hermes-gateway-control-daemon is only valid when AGENT=hermes", file=sys.stderr)
        return 1
    user = env.get("OC_USER", "hermes")
    try:
        pw = pwd.getpwnam(user)
    except KeyError:
        print(f"agent user not found: {user}", file=sys.stderr)
        return 1

    try:
        SOCKET_PATH.unlink()
    except FileNotFoundError:
        pass

    stop = False

    def _stop(_signum: int, _frame: object) -> None:
        nonlocal stop
        stop = True
        try:
            # Wake accept().
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
                s.settimeout(0.1)
                s.connect(str(SOCKET_PATH))
        except OSError:
            pass

    signal.signal(signal.SIGTERM, _stop)
    signal.signal(signal.SIGINT, _stop)

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as srv:
        srv.bind(str(SOCKET_PATH))
        os.chown(SOCKET_PATH, pw.pw_uid, pw.pw_gid)
        os.chmod(SOCKET_PATH, 0o660)
        srv.listen(16)
        srv.settimeout(1.0)
        while not stop:
            try:
                conn, _ = srv.accept()
            except socket.timeout:
                continue
            with conn:
                try:
                    data = conn.recv(8192)
                    if not data:
                        continue
                    req = json.loads(data.decode().strip())
                    if not isinstance(req, dict):
                        raise ValueError("request must be a JSON object")
                    send(conn, handle(req))
                except Exception as exc:  # Keep daemon alive after bad clients.
                    send(conn, {"returncode": 1, "stdout": "", "stderr": f"bad request: {exc}\n"})

    try:
        SOCKET_PATH.unlink()
    except FileNotFoundError:
        pass
    return 0


if __name__ == "__main__":
    raise SystemExit(serve())
