#!/usr/bin/env bash
set -euo pipefail

# Copy the live OpenClaw config into the git-backed repo, commit, and (if a
# remote is configured) push. No-ops cleanly when nothing changed.
# Runs as the agent user. Installed to /usr/local/bin by setup.sh.

# shellcheck source=/dev/null
[[ -f /etc/openclaw-lxc.env ]] && source /etc/openclaw-lxc.env

LIVE="${OC_LIVE:?OC_LIVE not set}"
REPO="${OC_REPO:?OC_REPO not set}"

if [[ -n "${CONFIG_GIT_SSH_KEY:-}" ]]; then
  export GIT_SSH_COMMAND="ssh -i ${CONFIG_GIT_SSH_KEY} -o IdentitiesOnly=yes -o StrictHostKeyChecking=yes"
fi

# Copy only the tracked files (allowlist) — never secrets/credentials/sessions.
install -d -m 700 "$REPO/cron"
install -m 600 "$LIVE/openclaw.json"        "$REPO/openclaw.json"
install -m 600 "$LIVE/exec-approvals.json"  "$REPO/exec-approvals.json" 2>/dev/null || true
install -m 600 "$LIVE/cron/jobs.json"       "$REPO/cron/jobs.json"      2>/dev/null || true

cd "$REPO"
git add -A
if git diff --cached --quiet; then
  echo "[config] no changes"
  exit 0
fi

git commit -m "sync: openclaw config $(date -Is)" >/dev/null
echo "[config] committed"

if git remote get-url origin >/dev/null 2>&1; then
  if git push >/dev/null 2>&1; then
    echo "[config] pushed"
  else
    echo "[config] WARN: push failed (commit is local; next run retries)" >&2
  fi
fi
