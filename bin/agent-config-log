#!/usr/bin/env bash
set -euo pipefail

# Read-only view of the agent config repo: status + recent history.
# Run as the agent user:  sudo -u <OC_USER> agent-config-log

# shellcheck source=/dev/null
[[ -f /etc/agent-lxc.env ]] && source /etc/agent-lxc.env
REPO="${AGENT_REPO:?AGENT_REPO not set}"

echo "== working tree =="
git -C "$REPO" status -sb
echo
echo "== recent history =="
git -C "$REPO" log --oneline -15
