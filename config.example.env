# openclaw-lxc-hardened — configuration
# Copy to config.env and edit. provision-lxc.sh reads this on the Proxmox host.

# ── Agent framework ──────────────────────────────────────────────────────
# openclaw : OpenClaw (Node). Validated end-to-end. Fully automated exposure.
# hermes   : NousResearch hermes-agent (Python). EXPERIMENTAL here — install +
#            non-root hardening + config history are automated, but network
#            exposure is left MANUAL (its bind/port/Tailscale config is not yet
#            verified against a live install). See README.
AGENT="openclaw"

# ── Container ────────────────────────────────────────────────────────────
CT_HOSTNAME="openclaw"
CT_DISK_GB="16"
CT_MEMORY_MB="4096"
CT_CORES="2"
CT_BRIDGE="vmbr0"
CT_VMID=""                # blank = auto-pick next free id
TMPL_STORAGE=""           # blank = auto-detect
ROOT_STORAGE=""           # blank = auto-detect

# ── Agent identity ───────────────────────────────────────────────────────
# The non-root user the agent runs as. NEVER root.
OC_USER="openclaw"

# ── Gateway exposure (OpenClaw only; Hermes exposure is manual for now) ───
# tailscale : bind loopback + Tailscale Serve (tailnet-only). RECOMMENDED.
# loopback  : bind loopback only (reach via SSH tunnel). Most locked-down.
# lan-token : bind LAN with a generated token. Least private.
EXPOSURE_MODE="tailscale"
TAILSCALE_AUTHKEY=""      # tskey-... for fully automated Tailscale bring-up

# ── Config history (git-backed) ──────────────────────────────────────────
CONFIG_GIT_REMOTE=""      # optional offsite remote; blank = local-only history
CONFIG_GIT_SSH_KEY=""     # SSH key (inside container) to push to the remote

# ── Optional modules ─────────────────────────────────────────────────────
ENABLE_BROWSER="true"     # Chromium for headless browser automation
ENABLE_SIGNAL="false"     # native signal-cli for the Signal channel
