# openclaw-lxc-hardened — configuration
# Copy to config.env and edit. provision-lxc.sh reads this on the Proxmox host.

# ── Container ────────────────────────────────────────────────────────────
CT_HOSTNAME="openclaw"
CT_DISK_GB="16"
CT_MEMORY_MB="4096"
CT_CORES="2"
CT_BRIDGE="vmbr0"
# Leave VMID empty to auto-pick the next free id.
CT_VMID=""
# Storage; leave empty to auto-detect (template store with vztmpl, rootfs store).
TMPL_STORAGE=""
ROOT_STORAGE=""

# ── Agent identity ───────────────────────────────────────────────────────
# The non-root user the OpenClaw gateway runs as. NEVER root.
OC_USER="openclaw"

# ── Gateway exposure ─────────────────────────────────────────────────────
# tailscale : bind loopback + Tailscale Serve (tailnet-only). RECOMMENDED.
# loopback  : bind loopback only (reachable via SSH tunnel). Most locked-down.
# lan-token : bind LAN with a generated token. Least private — only if you
#             understand the exposure. Adds real auth (never bind-wide + no-auth).
EXPOSURE_MODE="tailscale"
# For EXPOSURE_MODE=tailscale: a pre-authorized Tailscale auth key (tskey-...).
# Generate at https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=""

# ── Config history (git-backed) ──────────────────────────────────────────
# Optional remote for offsite config history. Leave empty for local-only
# commits (still recoverable on-box; just no offsite copy).
# Example: ssh://git@nas.local/volume1/git/openclaw-config.git
CONFIG_GIT_REMOTE=""
# SSH key path (inside the container) used to push to CONFIG_GIT_REMOTE.
CONFIG_GIT_SSH_KEY=""

# ── Optional modules ─────────────────────────────────────────────────────
ENABLE_BROWSER="true"     # install Chromium for OpenClaw's headless browser automation
ENABLE_SIGNAL="false"     # install signal-cli (native build) for the Signal channel
